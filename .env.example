NODE_ENV=development
PORT=3000
APP_NAME=NMSports API
API_PREFIX=api/v1

MONGODB_URI=mongodb://localhost:27017/nmsports

JWT_ACCESS_SECRET='your_jwt_access_secret_key'
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET='your_jwt_refresh_secret_key'
JWT_REFRESH_EXPIRES_IN=7d

SWAGGER_ENABLED=true
SWAGGER_TITLE=NMSports API
SWAGGER_DESCRIPTION=NMSports SaaS Platform API Documentation
SWAGGER_VERSION=1.0
SWAGGER_PATH=api/docs

# Rate Limiting
# Global throttle: max requests per TTL window (per IP)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Auth endpoints (stricter)
THROTTLE_AUTH_TTL=900000
THROTTLE_AUTH_LIMIT=10

# Public read endpoints (looser)
THROTTLE_PUBLIC_TTL=60000
THROTTLE_PUBLIC_LIMIT=300

# Security
REQUEST_SIZE_LIMIT=10kb
REQUEST_TIMEOUT_MS=30000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@nmsports.com
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=NMSports
SMTP_FROM_EMAIL=noreply@nmsports.com

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Notifications
NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=true